<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Bilgiler</title>
<style>
body{
  margin:0;
  background:#fff3e0;
  overflow:hidden;
  font-family:Arial, sans-serif;
}

.shaker{
  position:absolute;
  top:15%;
  left:50%;
  transform:translateX(-50%) rotate(-40deg);
  width:140px;
  animation:shake 0.5s infinite alternate;
  z-index:3;
}

@keyframes shake{
  from{transform:translateX(-50%) rotate(-35deg);}
  to{transform:translateX(-50%) rotate(-45deg);}
}

.spice{
  position:absolute;
  border-radius:50%;
  animation-name:fall;
  animation-timing-function:linear;
  animation-fill-mode:forwards;
  z-index:2;
}

@keyframes fall{
  0%{
    transform:translateY(0) translateX(0);
    opacity:1;
  }
  100%{
    transform:translateY(var(--dropY)) translateX(var(--driftX));
    opacity:0.95;
  }
}

.pile{
  position:absolute;
  left:50%;
  transform:translateX(-50%);
  bottom:72px;
  width:0;
  height:0;
  border-left:0 solid transparent;
  border-right:0 solid transparent;
  border-bottom:0 solid #8b5a2b;
  z-index:1;
  animation:pileGrow 3s linear forwards;
}

@keyframes pileGrow{
  0%{
    border-left-width:0;
    border-right-width:0;
    border-bottom-width:0;
  }
  35%{
    border-left-width:25px;
    border-right-width:25px;
    border-bottom-width:16px;
  }
  70%{
    border-left-width:55px;
    border-right-width:55px;
    border-bottom-width:34px;
  }
  100%{
    border-left-width:78px;
    border-right-width:78px;
    border-bottom-width:48px;
  }
}

.ground{
  position:absolute;
  left:50%;
  transform:translateX(-50%);
  bottom:60px;
  width:260px;
  height:10px;
  background:#8d6e63;
  border-radius:10px;
  z-index:0;
}

.content{
  display:none;
  text-align:center;
  margin-top:220px;
  font-size:22px;
  color:#4e342e;
  position:relative;
  z-index:4;
}
.content h1{
  margin-bottom:12px;
}
.content p{
  margin:8px 0;
}
</style>
</head>
<body>

<img src="salt.png" class="shaker" alt="Tuzluk">
<div class="pile"></div>
<div class="ground"></div>

<div class="content" id="content">
  <h1>AKSU BAHARAT</h1>
  <p>60 yıllık tecrübe</p>
  <p>Bursa Osmangazi Cumhuriyet Caddesi No 99 Taksim</p>
  <p>Telefon: 0 0224 223 7703</p>
</div>

<audio id="spiceSound" preload="auto">
  <source src="spice-sound.mp3" type="audio/mpeg">
</audio>

<script>
function randomColor(){
  const colors = ["#8B0000","#a0522d","#d4a017","#5c4033"];
  return colors[Math.floor(Math.random()*colors.length)];
}

function dropSpice(){
  const total = 220;

  for(let i=0;i<total;i++){
    let s = document.createElement("div");
    s.className = "spice";

    let size = Math.random()*5 + 3;
    let startX = window.innerWidth/2 + (Math.random()*90 - 45);
    let drift = Math.random()*70 - 10;
    let dropY = 430 + Math.random()*120;

    s.style.width = size + "px";
    s.style.height = size + "px";
    s.style.background = randomColor();
    s.style.left = startX + "px";
    s.style.top = "120px";
    s.style.setProperty("--driftX", drift + "px");
    s.style.setProperty("--dropY", dropY + "px");
    s.style.animationDuration = (2 + Math.random()*1) + "s";
    s.style.animationDelay = (Math.random()*0.8) + "s";

    document.body.appendChild(s);

    setTimeout(() => {
      s.remove();
    }, 3200);
  }
}

function playSound(){
  const sound = document.getElementById("spiceSound");
  sound.volume = 0.7;
  sound.currentTime = 0;
  sound.play().catch(() => {});
}

dropSpice();
playSound();

document.body.addEventListener("click", playSound, { once:true });

setTimeout(() => {
  document.getElementById("content").style.display = "block";
}, 3000);
</script>

</body>
</html>
